# ============================================================================
# GTFS Platform Configuration
# ============================================================================

# PostgreSQL Database Configuration
POSTGRES_DB=gtfs_transit
POSTGRES_USER=gtfs_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# pgAdmin Configuration (optional)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin_password
PGADMIN_PORT=5051

# ============================================================================
# Application Configuration
# ============================================================================

# Database URL - Used by Scraper, Viewer, and Planner
# If set: Applications use PostgreSQL database
# If not set or empty: Applications fallback to CSV files
DATABASE_URL=postgresql://gtfs_admin:your_secure_password_here@localhost:5432/gtfs_transit

# To disable database and use only CSV, comment out or leave empty:
# DATABASE_URL=

# GTFS Data Directory (fallback when database unavailable)
GTFS_DIR=gtfs

# Planner: print [planner.timing] phase durations to stderr (load, build_raptor_context, plan_multi, …)
# GTFS_PLANNER_TIMING=1

# Cache built RaptorContext to .cache/gtfs_raptor (gzip pickle); huge files, fast restarts
# GTFS_RAPTOR_CACHE=1
# GTFS_RAPTOR_CACHE_DIR=.cache/gtfs_raptor
